# udev rule for USBB-RELAY02 (16c0:05df) HID USB relay board
# Install: sudo cp 99-usb-relay.rules /etc/udev/rules.d/
# Reload:  sudo udevadm control --reload-rules && sudo udevadm trigger
# Then unplug and replug the board.
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="05df", MODE="0666"
